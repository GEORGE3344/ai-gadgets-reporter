# SMTP Server Configuration (e.g., smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Credentials (Use an App Password, NOT your main password if using Gmail)
SMTP_USER=your_email@gmail.com
